# Copy to .env and set your real values (not committed to git)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
JWT_SECRET=change-me-to-a-long-random-secret-key-at-least-32-chars
JWT_EXPIRATION_HOURS=24

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
# Host AMQP when connecting from Windows to Docker RabbitMQ: use port 56720
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
